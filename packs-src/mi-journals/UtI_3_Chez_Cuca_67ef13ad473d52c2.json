    {
      "_id": "901e4813575fb605",
      "name": "Dropping Clues & Debugging",
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "image": {},
      "video": {
        "controls": true,
        "volume": 0.5
      },
      "src": null,
      "text": {
        "format": 1,
        "content": "\n        <p>Lindy's screening is the gate. If the team can't talk their way in, the music-store cover, the surveillance gear, and the underground access all reward legwork and a quiet approach over a frontal one.</p>"
      },
