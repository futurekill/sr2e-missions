  "pages": [
    {
      "_id": "5c4bb05dbc66f761",
      "name": "Read to the Players",
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "image": {},
      "video": {
        "controls": true,
        "volume": 0.5
